# allowed request origins (comma-separated list, e.g. http://localhost:5173)
ALLOWED_ORIGINS=

# email recipient
CONTACT_EMAIL_TO=

# email sender address (must be verified domain in Resend/Brevo)
CONTACT_EMAIL_FROM=

# email api provider: 'resend' or 'brevo'
EMAIL_PROVIDER=

# email provider secret api key
EMAIL_API_KEY=
